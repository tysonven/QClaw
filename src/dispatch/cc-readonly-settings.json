{
  "$comment": "Slice 5 — Claude Code read-only audit policy (--settings). DEFENCE-IN-DEPTH only; the structural secret-read control is running CC as the unprivileged ccdispatch user (kernel perms). This deny-list is acknowledged enumeration and must not be relied on alone.",
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Write",
      "Edit",
      "NotebookEdit",
      "Read(/root/.quantumclaw/**)",
      "Read(**/.env)",
      "Read(/root/.ssh/**)",
      "Read(/home/*/.ssh/**)",
      "Read(/etc/ssh/**)",
      "Read(/root/.pm2/**)",
      "Read(/root/.claude.json)",
      "Read(/root/.config/**)",
      "Read(/root/.bash_history)",
      "Read(/root/.zsh_history)",
      "Read(/etc/sudoers)",
      "Read(/etc/sudoers.d/**)",
      "Read(/etc/shadow)",
      "Read(/proc/**)",
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(tee:*)",
      "Bash(dd:*)"
    ],
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)"
    ]
  }
