import { join } from 'path';
import { homedir } from 'os';
import { SecretStore } from './src/security/secrets.js';
import { loadConfig } from './src/core/config.js';
import { AgentRegistry } from './src/agents/registry.js';
import { ModelRouter } from './src/models/router.js';
import { MemoryManager } from './src/memory/manager.js';
import { SkillLoader } from './src/skills/loader.js';
import { ExecApprovals } from './src/security/approvals.js';
import { TrustKernel } from './src/security/trust-kernel.js';
import { AuditLog } from './src/security/audit.js';
import { log } from './src/core/logger.js';

async function main() {
  log.info('Testing Approval Gate System\n');

  const config = await loadConfig();
  const secrets = new SecretStore({ _dir: join(homedir(), '.quantumclaw') });
  await secrets.load();

  const memory = new MemoryManager(config, secrets);
  await memory.connect();

  const router = new ModelRouter(config, secrets);
  const skills = new SkillLoader(config);
  await skills.loadAll();

  const trustKernel = new TrustKernel(config);
  await trustKernel.load();

  const audit = new AuditLog(config);
  const approvals = new ExecApprovals(config);
  approvals.attach(null);

  const agents = new AgentRegistry(config, {
    memory,
    router,
    skills,
    trustKernel,
    audit,
    secrets,
    config,
    approvals
  });
  await agents.loadAll();

  const charlie = agents.get('charlie') || agents.primary();
  if (!charlie) {
    log.error('Charlie not found');
    process.exit(1);
  }

  log.success('Charlie loaded');
  log.info('\nTesting: "show me last 5 stripe customers"\n');

  try {
    const result = await charlie.process('show me the last 5 stripe customers', {
      channel: 'test-cli',
      userId: 'test-user'
    });

    console.log('\n━━━ RESULT ━━━');
    console.log(result.content);
    console.log(`\nTier: ${result.tier} | Model: ${result.model || 'reflex'}`);

    const pending = approvals.pending();
    if (pending.length > 0) {
      console.log('\n━━━ PENDING APPROVALS ━━━');
      for (const p of pending) {
        console.log(`[${p.id}] ${p.agent} -> ${p.action} (${p.risk_level})`);
      }
      console.log(`\nApprove in Telegram: /approve ${pending[0].id}`);
    } else {
      console.log('\nNo approvals triggered');
    }
  } catch (err) {
    log.error(`Test failed: ${err.message}`);
    process.exit(1);
  }

  process.exit(0);
}

main();
