        "jsCode": "const result = $input.first().json;\nconst highlights = result.auto_highlights_result?.results || [];\nconst top5 = highlights\n  .sort((a, b) => b.rank - a.rank)\n  .slice(0, 5)\n  .map(h => {\n    const mins = Math.floor(h.timestamps[0].start / 60000);\n    const secs = Math.floor((h.timestamps[0].start % 60000) / 1000);\n    return `${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')} \u2014 \"${h.text}\"`;\n  });\n\nconst highlightText = top5.length > 0 \n  ? top5.join('\\n')\n  : 'No highlights detected';\n\nreturn [{ json: { \n  ...result,\n  highlightTimestamps: highlightText,\n  highlightCount: top5.length\n}}];"
      },
