    {
      "parameters": {
        "jsCode": "const text = $input.first().json.content[0].text;\n\n// Convert markdown to basic HTML\nlet html = text\n  // Headers\n  .replace(/^### (.+)$/gm, '<h3>$1</h3>')\n  .replace(/^## (.+)$/gm, '<h2>$1</h2>')\n  .replace(/^# (.+)$/gm, '<h1>$1</h1>')\n  // Bold\n  .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n  // Italic\n  .replace(/\\*(.+?)\\*/g, '<em>$1</em>')\n  // Horizontal rule\n  .replace(/^---$/gm, '<hr>')\n  // Unordered lists\n  .replace(/^\\- (.+)$/gm, '<li>$1</li>')\n  .replace(/(<li>.*<\\/li>\\n?)+/g, '<ul>$&</ul>')\n  // Line breaks to paragraphs\n  .split('\\n\\n')\n  .map(p => p.trim())\n  .filter(p => p && !p.startsWith('<h') && !p.startsWith('<ul') && !p.startsWith('<hr'))\n  .map(p => p.startsWith('<') ? p : `<p>${p}</p>`)\n  .join('\\n');\n\nreturn [{ json: { ...$input.first().json, htmlContent: html } }];"
      },
      "id": "convert-to-html",
      "name": "Convert to HTML",
      "type": "n8n-nodes-base.code",
