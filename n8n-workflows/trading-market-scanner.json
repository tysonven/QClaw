        "id": "merge-all",
        "name": "Merge All",
        "type": "n8n-nodes-base.merge",
        "typeVersion": 2.1,
        "position": [
          1808,
          752
        ]
      },
      {
        "parameters": {
          "jsCode": "const isWeekend = [0,6].includes(new Date().getDay());\nconst isMonday = new Date().getDay() === 1;\nconst edgeThreshold = isMonday ? 20 : 30;\n\nconst { sims: allSims } = $input.all().find(i => i.json.sims)?.json || { sims: [] };\n// Skip gold and oil sims on weekends\nconst sims = isWeekend \n  ? allSims.filter(s => s.asset === 'btc')\n  : allSims;\nconst markets = $input.all().filter(i => i.json.question && i.json.outcomePrices).map(i => i.json);\n\nconst results = [];\nfor (const sim of sims) {\n  for (const m of markets) {\n    const text = (m.question || '').toLowerCase();\n    const isAsset = \n      sim.asset === 'gold'  ? (text.includes('gold') || text.includes('xau')) :\n      sim.asset === 'btc'   ? (text.includes('btc') || text.includes('bitcoin')) :\n      sim.asset === 'wti'   ? (text.includes('wti') || text.includes('crude') || text.includes('oil') || text.includes('west texas')) :\n      sim.asset === 'brent' ? (text.includes('brent') || text.includes('crude') || text.includes('oil')) :\n      false;\n    \n    if (!isAsset) continue;\n    \n    // Check if market mentions a price in range of our target (\u00b15%)\n    const priceMatches = text.match(/\\$[\\d,]+k?/g) || [];\n    const marketPrices = priceMatches.map(p => {\n      const clean = p.replace(/[$,k]/g,'');\n      return p.includes('k') ? parseFloat(clean) * 1000 : parseFloat(clean);\n    });\n    \n    const inRange = marketPrices.some(p => \n      Math.abs(p - sim.target) / sim.target < 0.05\n    );\n    \n    if (!inRange && marketPrices.length > 0) continue;\n    if (marketPrices.length === 0 && !isAsset) continue;\n    \n    let yesPrice = null;\n    try {\n      const p = typeof m.outcomePrices==='string' ? JSON.parse(m.outcomePrices) : m.outcomePrices;\n      if (p?.[0]) yesPrice = parseFloat(p[0]);\n    } catch {}\n    \n    if (yesPrice === null) continue;\n    \n    const edge = Math.round((sim.probability - yesPrice) * 1000) / 10;\n    results.push({\n      market_id: m.id || m.conditionId,\n      question: m.question,\n      yes_price: yesPrice,\n      sim_probability: sim.probability,\n      edge,\n      asset: sim.asset,\n      target: sim.target,\n      label: sim.label,\n      horizon: sim.horizon,\n      volume: parseFloat(m.volume || 0),\n      current_price: sim.current_price,\n      end_date: m.endDate\n    });\n  }\n}\n\nconst highEdge = results.filter(r => r.edge > edgeThreshold && r.volume > 50000);\n\n// Clean sims for Supabase (only columns that exist in trading_simulations table)\nconst cleanSims = sims.map(s => ({\n  asset: s.asset,\n  probability: s.probability,\n  confidence_lower: s.confidence_lower,\n  confidence_upper: s.confidence_upper,\n  current_price: s.current_price,\n  macro_factors: s.macro_factors,\n  simulation_count: s.simulation_count || 1000\n}));\n\nreturn [{ json: { \n  results, \n  sims: cleanSims, \n  highEdge, \n  markets_scanned: markets.length,\n  scanned_at: new Date().toISOString(),\n  gold_price: allSims.find(s=>s.asset==='gold')?.current_price,\n  btc_price: allSims.find(s=>s.asset==='btc')?.current_price,\n  wti_price: allSims.find(s=>s.asset==='wti')?.current_price,\n  brent_price: allSims.find(s=>s.asset==='brent')?.current_price\n}}];"
        },
