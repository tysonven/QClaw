        "parameters": {
          "jsCode": "const goldItem = $input.all().find(i => i.json.asset === 'gold');\nconst btcItem = $input.all().find(i => i.json.asset === 'btc');\nconst wtiItem = $input.all().find(i => i.json.asset === 'wti');\nconst brentItem = $input.all().find(i => i.json.asset === 'brent');\nconst goldPrice = goldItem?.json.current_price || 4700;\nconst btcPrice = btcItem?.json.current_price || 69000;\nconst wtiPrice = wtiItem?.json.current_price || 75;\nconst brentPrice = brentItem?.json.current_price || 78;\n\nconst targets = [\n  { asset: 'gold', label: 'short',  target: Math.round(goldPrice * 1.010), horizon: 14 },\n  { asset: 'gold', label: 'medium', target: Math.round(goldPrice * 1.025), horizon: 30 },\n  { asset: 'btc',  label: 'short',  target: Math.round(btcPrice  * 1.050), horizon: 14 },\n  { asset: 'btc',  label: 'medium', target: Math.round(btcPrice  * 1.100), horizon: 30 },\n  { asset: 'wti',   label: 'short',  target: +(wtiPrice   * 1.03).toFixed(2), horizon: 14 },\n  { asset: 'wti',   label: 'medium', target: +(wtiPrice   * 1.08).toFixed(2), horizon: 30 },\n  { asset: 'brent', label: 'short',  target: +(brentPrice * 1.03).toFixed(2), horizon: 14 },\n  { asset: 'brent', label: 'medium', target: +(brentPrice * 1.08).toFixed(2), horizon: 30 },\n];\nreturn targets.map(t => ({ json: t }));"
        },
