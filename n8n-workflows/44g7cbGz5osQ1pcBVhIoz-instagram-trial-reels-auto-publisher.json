        "jsCode": "// Filter out rows where Posted (Checkbox) is already true\n// Handles both boolean true and string \"TRUE\"\nreturn $input.all().filter(item => {\n  const posted = item.json['Posted (Checkbox)'];\n  // Exclude if posted is boolean true, string \"TRUE\", or string \"true\"\n  if (posted === true) return false;\n  if (typeof posted === 'string' && posted.toUpperCase() === 'TRUE') return false;\n  return true;\n});"
      },
