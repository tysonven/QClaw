      "parameters": {
        "jsCode": "const raw = $input.item.json.message?.content || $input.item.json.choices?.[0]?.message?.content || '';\nconst comment = raw.trim();\n// Quality gate: must be between 20 and 280 characters\nconst isQuality = comment.length >= 20 && comment.length <= 280;\nreturn { ...($input.item.json), comment_text: comment, comment_quality_pass: isQuality };"
      },
