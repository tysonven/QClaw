      "parameters": {
        "jsCode": "\n// Merge engagement weight data with the post data\nconst postData = $('LinkedIn Feed Monitor').first().json;\nconst weightsRaw = $('Fetch Engagement Weights').first().json;\n\n// Weights may be an array (Supabase returns array) or empty\nconst weights = Array.isArray(weightsRaw) && weightsRaw.length > 0 ? weightsRaw[0] : null;\n\nconst minScore = weights?.recommended_min_score || 7;\nconst topTopics = weights?.top_performing_topics || [];\nconst commentRate = weights?.comment_connection_rate || 0;\nconst likeRate = weights?.like_connection_rate || 0;\n\nreturn [{\n  json: {\n    ...postData,\n    engagement_context: {\n      min_score_threshold: minScore,\n      top_performing_topics: topTopics,\n      comment_connection_rate: commentRate,\n      like_connection_rate: likeRate,\n      has_weight_data: weights !== null\n    }\n  }\n}];\n"
      },
