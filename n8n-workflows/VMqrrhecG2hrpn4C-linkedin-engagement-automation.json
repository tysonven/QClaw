    {
      "parameters": {
        "jsCode": "// Fetch today's engagement rate limit from Supabase\nconst today = new Date().toISOString().split('T')[0];\nconst url = 'https://zshmlgtvhdneekbfcyjc.supabase.co/rest/v1/engagement_rate_limits?date=eq.' + today + '&select=*';\n\nlet todayCount = 0;\ntry {\n  const response = await $http.get(url, {\n    headers: {\n      'apikey': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpzaG1sZ3R2aGRuZWVrYmZjeWpjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Mjc5NzI4OSwiZXhwIjoyMDg4MzczMjg5fQ.Jop1GNUQijVBzV8KEYLfgpdkdS8b-KhwHFtNY2kH23Y',\n      'Authorization': 'Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpzaG1sZ3R2aGRuZWVrYmZjeWpjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3Mjc5NzI4OSwiZXhwIjoyMDg4MzczMjg5fQ.Jop1GNUQijVBzV8KEYLfgpdkdS8b-KhwHFtNY2kH23Y',\n      'Content-Type': 'application/json'\n    }\n  });\n  const data = response.data;\n  if (Array.isArray(data) && data.length > 0) {\n    todayCount = data[0].engagement_count || 0;\n  }\n} catch(e) {\n  // If request fails, default to 0 (allow engagement)\n  todayCount = 0;\n}\n\nreturn { engagement_count: todayCount, date: today };"
      },
      "id": "b2000001-0000-0000-0000-000000000005",
      "name": "Check Engagement Rate Limit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
