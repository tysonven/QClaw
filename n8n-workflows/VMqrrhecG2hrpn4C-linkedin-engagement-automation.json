    {
      "parameters": {
        "jsCode": "const analysis = $('Parse Content Analysis').item.json;\n// rateData may be an array (Supabase returns array) or empty object if no record today\nconst rateRaw = $input.item.json;\n// Handle both array response and empty object\nlet todayCount = 0;\nif (Array.isArray(rateRaw) && rateRaw.length > 0) {\n  todayCount = rateRaw[0].engagement_count || 0;\n} else if (rateRaw && rateRaw.engagement_count !== undefined) {\n  todayCount = rateRaw.engagement_count || 0;\n}\nconst score = analysis.engagement_score || 0;\nconst engType = analysis.engagement_type || 'skip';\nconst underLimit = todayCount < 30;\nconst shouldEngage = score >= 7 && engType !== 'skip' && underLimit;\nreturn {\n  ...analysis,\n  today_count: todayCount,\n  under_limit: underLimit,\n  should_engage: shouldEngage\n};"
      },
