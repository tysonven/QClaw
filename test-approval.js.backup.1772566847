#!/usr/bin/env node

import dotenv from 'dotenv';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';
import { AgentRegistry } from './src/agents/registry.js';
import { ToolRegistry } from './src/tools/registry.js';
import { ToolExecutor } from './src/tools/executor.js';
import ApprovalGates from './src/security/approvalGates.js';
import RateLimiter from './src/security/rateLimiter.js';
import ContentQueue from './src/security/contentQueue.js';
import { SecretStore } from './src/security/secrets.js';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

dotenv.config();

async function main() {
  console.log('=== Charlie Approval Gate Test ===\n');

  // Initialize security layer
  const secretStore = new SecretStore();
  await secretStore.init();

  // Initialize tools system
  const toolRegistry = new ToolRegistry(join(__dirname, 'src/tools'));
  await toolRegistry.init();

  const approvalGates = new ApprovalGates();
  const rateLimiter = new RateLimiter();
  const contentQueue = new ContentQueue();

  const toolExecutor = new ToolExecutor(
    toolRegistry,
    approvalGates,
    rateLimiter,
    contentQueue,
    secretStore
  );

  // Initialize Charlie with tools
  const registry = new AgentRegistry({
    agentId: 'charlie',
    workspaceRoot: join(process.env.HOME, '.quantumclaw/workspace'),
    model: 'claude-opus-4-20250514',
    toolExecutor
  });

  await registry.init();

  console.log('Agent initialized. Skills available:');
  console.log(Object.keys(registry.aid.skills).join(', '));
  console.log('');

  // Test 1: Simple query that should use reflex
  console.log('--- Test 1: Reflex Tier ---');
  const greeting = await registry.process({
    channel: 'test',
    threadId: 'test-001',
    userId: 'tyson',
    username: 'Tyson',
    body: 'hello'
  });
  console.log('Response:', greeting);
  console.log('');

  // Test 2: Query requiring Stripe skill
  console.log('--- Test 2: Stripe Skill (Should require approval) ---');
  try {
    const stripeQuery = await registry.process({
      channel: 'test',
      threadId: 'test-002',
      userId: 'tyson',
      username: 'Tyson',
      body: 'show me recent stripe customers'
    });
    console.log('Response:', stripeQuery);
  } catch (error) {
    console.error('Error:', error.message);
  }
  console.log('');

  // Test 3: Direct skill execution
  console.log('--- Test 3: Direct Skill Execution ---');
  try {
    const skillResult = await registry._executeSkillHttp(
      'stripe',
      'GET',
      '/customers',
      { limit: 5 }
    );
    console.log('Skill result:', JSON.stringify(skillResult, null, 2));
  } catch (error) {
    console.error('Skill execution error:', error.message);
  }

  console.log('\n=== Test Complete ===');
}

main().catch(console.error);
